<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/root.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/blog.css') }}">
    <title>{{ blog.title }}</title>
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-pb1a8fR2IG23QMGYBk8zQ7C0r4kOG55G4+7RThd7GxVbxmYFZHzqLTXW2dEVxErbqD0kKcl00Kd6cTDyXv4qOQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="shortcut icon" href="" type="image">
</head>
<body>
    {% include "snippets/navbar.jinja-html" %}

    <div class="article-wrapper">
        <div class="progress-indicator" id="progressBar"></div>

        <article class="article-container">
            <header class="article-header-minimal">
                <div class="header-top-row">
                    <span class="article-type-badge"><a href="/blog?type={{ blog.type | lower if blog.type else 'article' }}">{{ blog.type if blog.type else "Article" }}</a></span>
                    <div class="category-list">
                        {% for cat in blog.categories %}
                            <span class="category-tag">{{ cat }}</span>
                        {% endfor %}
                    </div>
                </div>
                
                <h1 class="article-display-title">{{ blog.title }}</h1>
                
                <div class="article-author-bar">
                    <div class="author-group">
                        <div class="avatar-ring">
                            {% for name in blog.author %}
                                <img src="https://ui-avatars.com/api/?name={{ name }}&background=25a1a7&color=fff" 
                                    alt="{{ name }}" class="avatar-img">
                            {% endfor %}
                        </div>
                        <div class="author-meta">
                            <span class="names">{{ blog.author | join(', ') }}</span>
                            <span class="timestamp">{{ blog.time_created | datetimeformat }} • 4 min read</span>
                        </div>
                    </div>
                    <div class="action-icons">
                        <i class="fa-regular fa-bookmark"></i>
                        <i class="fa-regular fa-share-from-square"></i>
                    </div>
                </div>
            </header>

            <div class="glass-article-body">
                <figure class="featured-figure">
                    <img src="{{ blog.image_url }}" alt="{{ blog.title }}" class="featured-image">
                </figure>

                <section class="main-text-flow">
                    {{ blog.content_raw | safe }}
                </section>

                <footer class="article-end">
                    <h4 class="footer-label">Related Tags</h4>
                    <div class="tag-row-modern">
                        {% for tag in blog.tags %}
                            <a href="/blog?tags={{ tag }}" class="modern-tag">
                                <span class="tag-hash">#</span>{{ tag }}
                            </a>
                        {% endfor %}
                    </div>
                </footer>
            </div>

            <section class="see-also-section">
                <h3 class="section-heading">See also</h3>
                <div class="related-grid">
                    {% for i in range(3) %}
                    <div class="related-card-glass">
                        <div class="placeholder-img"></div>
                        <div class="related-content">
                            <span class="related-cat">Category</span>
                            <h4>Placeholder for a Related Article</h4>
                            <span class="related-meta">Mar 12 • 5 min read</span>
                        </div>
                    </div>
                    {% endfor %}
                </div>
            </section>
        </article>
    </div>
    {% include "snippets/footer.jinja-html" %}
    <script src="{{ url_for('static', filename='js/global.js') }}"></script>
    <script src="{{ url_for('static', filename='js/blog.js') }}"></script>
</body>
</html>