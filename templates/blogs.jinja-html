<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog – Jackstar’s Journal</title>
    <meta name="description" content="Read articles, guides, and opinions from Jackstar on web development, design, and technology.">
    <meta name="author" content="Jackstar">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/root.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/blogs.css') }}">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" integrity="sha512-pb1a8fR2IG23QMGYBk8zQ7C0r4kOG55G4+7RThd7GxVbxmYFZHzqLTXW2dEVxErbqD0kKcl00Kd6cTDyXv4qOQ==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="shortcut icon" href="" type="image">
</head>
<body>
    {% include "snippets/navbar.jinja-html" %}

    <main class="blog-container container">
        <header class="blog-minimal-header">
            <div class="section-label">Journal</div>
            <h1>Articles & Perspectives</h1>
        </header>

        <section class="blog-toolbar">
            <div class="search-wrapper">
                <input type="text" placeholder="Search articles..." id="search-input">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
            </div>
            
            <button class="filter-toggle-btn" id="filter-btn">
                <i class="fa-solid fa-sliders"></i>
                <span>Filters</span>
            </button>
        </section>

        <section class="filter-drawer" id="filter-drawer">
            <div class="drawer-inner">
                <div class="filter-col filter-group">
                    <label><i class="fa-solid fa-sort"></i> Sort</label>
                    <div class="filter-select-wrapper">
                        <select id="sort-select">
                            <option value="newest">🔽 Newest</option>
                            <option value="oldest">🔼 Oldest</option>
                        </select>
                        <i class="fa-solid fa-chevron-down dropdown-icon"></i>
                    </div>
                </div>
                <div class="filter-col filter-group">
                    <label><i class="fa-solid fa-folder-open"></i> Topics</label>
                    <div class="filter-select-wrapper">
                        <select id="category-select">
                            <option value="">All</option>
                            {% for topic in settings.topics %}
                                <option>{{ topic }}</option>
                            {% endfor %}
                        </select>
                        <i class="fa-solid fa-chevron-down dropdown-icon"></i>
                    </div>
                </div>
                <div class="filter-col filter-group">
                    <label><i class="fa-solid fa-tags"></i> Tags</label>
                    <div class="tag-input">
                        <input type="text" placeholder="e.g. Python, UI Design" id="tags-input">
                        <div class="tag-suggestions">
                            <span>#Python</span>
                            <span>#AI</span>
                            <span>#UI-Design</span>
                        </div>
                    </div>
                </div>
                <div class="filter-col filter-group">
                    <label><i class="fa-solid fa-calendar-days"></i> Date</label>
                    <div class="filter-date-range">
                        <input type="date" id="start-date"><span>to</span><input type="date" id="end-date">
                    </div>
                </div>
                <div class="filter-col filter-group filter-collapsible">
                    <input type="checkbox" id="reading-time-toggle" class="filter-toggle-checkbox">
                    <label for="reading-time-toggle" class="filter-label-collapsible"><i class="fa-solid fa-clock"></i> Reading Time <i class="fa-solid fa-chevron-down"></i></label>
                    <div class="filter-list-group">
                        <label class="filter-list-item"><input type="checkbox" value="short"><i class="fa-solid fa-rabbit"></i><span>Short (&lt;5 min)</span></label>
                        <label class="filter-list-item"><input type="checkbox" value="medium"><i class="fa-solid fa-person-hiking"></i><span>Medium (5‑15 min)</span></label>
                        <label class="filter-list-item"><input type="checkbox" value="deep"><i class="fa-solid fa-book"></i><span>Deep Dive (&gt;15 min)</span></label>
                    </div>
                </div>
                <div class="filter-col filter-group filter-collapsible">
                    <input type="checkbox" id="type-toggle" class="filter-toggle-checkbox">
                    <label for="type-toggle" class="filter-label-collapsible"><i class="fa-solid fa-list"></i> Type <i class="fa-solid fa-chevron-down"></i></label>
                    <div class="filter-list-group">
                        {% for type in settings.types %}
                            <label class="filter-list-item">
                                <input type="checkbox" value="{{ type.name }}">
                                <i class="{{ type.icon }}"></i>
                                <span>{{ type.name }}</span>
                            </label>
                        {% endfor %}
                    </div>
                </div>
            </div>
            <div class="filter-actions">
                <button class="clear-filters-btn"><i class="fa-solid fa-rotate-left"></i> Clear All</button>
                <button class="apply-filters-btn"><i class="fa-solid fa-check"></i> Apply Filters</button>
            </div>
        </section>

        <section class="blog-list">
            {% if blogs %}
                {% for blog in blogs %}
                    <article class="blog-card-v2">
                        <div class="card-image">
                            <img src="{{ blog.image_url }}" alt="{{ blog.title }} Cover">
                            
                            <div class="glass-tags-container">
                                {% if blog.tags %}
                                    {% for tag in blog.tags[:3] %}
                                        <span class="glass-tag">#{{ tag }}</span>
                                    {% endfor %}
                                {% else %}
                                    <span class="glass-tag">General</span>
                                {% endif %}
                            </div>
                        </div>
                        <div class="card-content">
                            <div class="card-meta">
                                <span class="reading-time"><i class="fa-regular fa-clock"></i> {{ blog.reading_time|default('5') }} min read</span>
                                <span class="dot">•</span>
                                <span class="date">{{ blog.time_created | datetimeformat }}</span>
                            </div>
                            
                            <a href="/blog/{{ blog.id }}" class="card-title">
                                <h2>{{ blog.title }}</h2>
                            </a>
                            
                            <div class="title-divider"></div>
                            
                            <p>{{ blog.content_raw | truncate(150) }}</p>
                            
                            <div class="author-modern">
                                <div class="author-avatar"><i class="fa-solid fa-user"></i></div>
                                <div class="author-details">
                                    <span class="author-label">By</span>
                                    <span class="author-name">{{ blog.author | join(', ') }}</span>
                                </div>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            {% else %}
                <p class="no-results">
                    {% if search_query %}
                        No articles found matching "{{ search_query }}". Try different keywords.
                    {% else %}
                        No articles found with the current filters. Try adjusting your search criteria.
                    {% endif %}
                </p>
            {% endif %}
        </section>

        <div class="blog-load-more">
            <button class="btn-load-more"><i class="fa-solid fa-arrow-down"></i> Load More Articles</button>
        </div>
    </main>
    {% include "snippets/footer.jinja-html" %}
    <script src="{{ url_for('static', filename='js/global.js') }}"></script>
    <script src="{{ url_for('static', filename='js/blogs.js') }}"></script>
</body>
</html>