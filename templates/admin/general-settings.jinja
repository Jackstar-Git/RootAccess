<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="{{ url_for('static', filename='assets/images/logos/LogoBrand.png') }}" type="image/png">
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link rel="preload" href="{{ url_for('static', filename='/assets/fonts/Montserrat/Montserrat-VariableFont_wght.woff2') }}" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="{{ url_for('static', filename='/assets/fonts/Montserrat/Montserrat-Italic-VariableFont_wght.woff2') }}" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="preload" href="{{ url_for('static', filename='css/root.css') }}" as="style">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/root.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/admin/general-settings.css') }}">
    <title>General Settings</title>
</head>
<body>
    <div class="main-container">
        {% include "admin/sidebar.jinja" %}
        <div class="main-content">
            <button class="mobile-menu-btn" id="mobileMenuBtn" type="button" title="Toggle Menu" aria-label="Toggle navigation menu">
                <i class="fa-solid fa-bars"></i>
            </button>
            <input type="hidden" id="csrf_token" value="{{ generate_token() }}">
            
            <div class="filter-bar">
                <div class="filter-controls">
                    <h2>General Settings</h2>
                </div>
                <button class="btn-primary" onclick="submitGeneralSettings()">
                    <i class="fa-solid fa-floppy-disk"></i> Save Settings
                </button>
            </div>

            <!-- Admin Password Section -->
            <div class="settings-card">
                <h3 class="section-title">Security Settings</h3>
                <form id="adminPasswordForm">
                    <div class="form-group">
                        <label for="admin_password">Admin Password</label>
                        <div class="password-input-group">
                            <input type="password" id="admin_password" name="admin_password" placeholder="Enter new admin password (leave blank to keep current)">
                            <button type="button" class="toggle-password-btn" onclick="togglePasswordVisibility('admin_password')" title="Toggle password visibility">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <div class="form-group">
                        <label for="admin_password_confirm">Confirm Password</label>
                        <div class="password-input-group">
                            <input type="password" id="admin_password_confirm" name="admin_password_confirm" placeholder="Confirm new admin password">
                            <button type="button" class="toggle-password-btn" onclick="togglePasswordVisibility('admin_password_confirm')" title="Toggle password visibility">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>

            <!-- General Settings Section -->
            <div class="settings-card">
                <h3 class="section-title">General Configuration</h3>
                <form id="generalSettingsForm">
                    <div class="settings-grid">
                        <div class="form-group">
                            <label for="timezone">Timezone</label>
                            <select id="timezone" name="timezone" onchange="handleTimezoneChange()">
                                <option value="UTC -12" {% if settings.get('timezone') == 'UTC -12' %}selected{% endif %}>UTC -12</option>
                                <option value="UTC -11" {% if settings.get('timezone') == 'UTC -11' %}selected{% endif %}>UTC -11</option>
                                <option value="UTC -10" {% if settings.get('timezone') == 'UTC -10' %}selected{% endif %}>UTC -10</option>
                                <option value="UTC -9.5" {% if settings.get('timezone') == 'UTC -9.5' %}selected{% endif %}>UTC -9.5</option>
                                <option value="UTC -9" {% if settings.get('timezone') == 'UTC -9' %}selected{% endif %}>UTC -9</option>
                                <option value="UTC -8.5" {% if settings.get('timezone') == 'UTC -8.5' %}selected{% endif %}>UTC -8.5</option>
                                <option value="UTC -8" {% if settings.get('timezone') == 'UTC -8' %}selected{% endif %}>UTC -8 (Pacific Time)</option>
                                <option value="UTC -7" {% if settings.get('timezone') == 'UTC -7' %}selected{% endif %}>UTC -7 (Mountain Time)</option>
                                <option value="UTC -6" {% if settings.get('timezone') == 'UTC -6' %}selected{% endif %}>UTC -6 (Central Time)</option>
                                <option value="UTC -5.5" {% if settings.get('timezone') == 'UTC -5.5' %}selected{% endif %}>UTC -5.5</option>
                                <option value="UTC -5" {% if settings.get('timezone') == 'UTC -5' %}selected{% endif %}>UTC -5 (Eastern Time)</option>
                                <option value="UTC -4.5" {% if settings.get('timezone') == 'UTC -4.5' %}selected{% endif %}>UTC -4.5</option>
                                <option value="UTC -4" {% if settings.get('timezone') == 'UTC -4' %}selected{% endif %}>UTC -4</option>
                                <option value="UTC -3.5" {% if settings.get('timezone') == 'UTC -3.5' %}selected{% endif %}>UTC -3.5</option>
                                <option value="UTC -3" {% if settings.get('timezone') == 'UTC -3' %}selected{% endif %}>UTC -3</option>
                                <option value="UTC -2" {% if settings.get('timezone') == 'UTC -2' %}selected{% endif %}>UTC -2</option>
                                <option value="UTC -1" {% if settings.get('timezone') == 'UTC -1' %}selected{% endif %}>UTC -1</option>
                                <option value="UTC" {% if settings.get('timezone') == 'UTC' %}selected{% endif %}>UTC (London)</option>
                                <option value="UTC +1" {% if settings.get('timezone') == 'UTC +1' %}selected{% endif %}>UTC +1 (Central Europe)</option>
                                <option value="UTC +2" {% if settings.get('timezone') == 'UTC +2' %}selected{% endif %}>UTC +2</option>
                                <option value="UTC +3" {% if settings.get('timezone') == 'UTC +3' %}selected{% endif %}>UTC +3 (Moscow)</option>
                                <option value="UTC +3.5" {% if settings.get('timezone') == 'UTC +3.5' %}selected{% endif %}>UTC +3.5</option>
                                <option value="UTC +4" {% if settings.get('timezone') == 'UTC +4' %}selected{% endif %}>UTC +4 (UAE)</option>
                                <option value="UTC +4.5" {% if settings.get('timezone') == 'UTC +4.5' %}selected{% endif %}>UTC +4.5</option>
                                <option value="UTC +5" {% if settings.get('timezone') == 'UTC +5' %}selected{% endif %}>UTC +5</option>
                                <option value="UTC +5.5" {% if settings.get('timezone') == 'UTC +5.5' %}selected{% endif %}>UTC +5.5 (India)</option>
                                <option value="UTC +5.75" {% if settings.get('timezone') == 'UTC +5.75' %}selected{% endif %}>UTC +5.75</option>
                                <option value="UTC +6" {% if settings.get('timezone') == 'UTC +6' %}selected{% endif %}>UTC +6</option>
                                <option value="UTC +6.5" {% if settings.get('timezone') == 'UTC +6.5' %}selected{% endif %}>UTC +6.5</option>
                                <option value="UTC +7" {% if settings.get('timezone') == 'UTC +7' %}selected{% endif %}>UTC +7</option>
                                <option value="UTC +8" {% if settings.get('timezone') == 'UTC +8' %}selected{% endif %}>UTC +8 (Singapore)</option>
                                <option value="UTC +8.45" {% if settings.get('timezone') == 'UTC +8.45' %}selected{% endif %}>UTC +8.45</option>
                                <option value="UTC +9" {% if settings.get('timezone') == 'UTC +9' %}selected{% endif %}>UTC +9 (Japan)</option>
                                <option value="UTC +9.5" {% if settings.get('timezone') == 'UTC +9.5' %}selected{% endif %}>UTC +9.5</option>
                                <option value="UTC +10" {% if settings.get('timezone') == 'UTC +10' %}selected{% endif %}>UTC +10 (Australia)</option>
                                <option value="UTC +10.5" {% if settings.get('timezone') == 'UTC +10.5' %}selected{% endif %}>UTC +10.5</option>
                                <option value="UTC +11" {% if settings.get('timezone') == 'UTC +11' %}selected{% endif %}>UTC +11</option>
                                <option value="UTC +12" {% if settings.get('timezone') == 'UTC +12' %}selected{% endif %}>UTC +12</option>
                                <option value="UTC +12.45" {% if settings.get('timezone') == 'UTC +12.45' %}selected{% endif %}>UTC +12.45</option>
                                <option value="UTC +13" {% if settings.get('timezone') == 'UTC +13' %}selected{% endif %}>UTC +13</option>
                                <option value="UTC +14" {% if settings.get('timezone') == 'UTC +14' %}selected{% endif %}>UTC +14</option>
                                <option value="custom" {% if settings.get('timezone') and settings.get('timezone') not in ['UTC -12', 'UTC -11', 'UTC -10', 'UTC -9.5', 'UTC -9', 'UTC -8.5', 'UTC -8', 'UTC -7', 'UTC -6', 'UTC -5.5', 'UTC -5', 'UTC -4.5', 'UTC -4', 'UTC -3.5', 'UTC -3', 'UTC -2', 'UTC -1', 'UTC', 'UTC +1', 'UTC +2', 'UTC +3', 'UTC +3.5', 'UTC +4', 'UTC +4.5', 'UTC +5', 'UTC +5.5', 'UTC +5.75', 'UTC +6', 'UTC +6.5', 'UTC +7', 'UTC +8', 'UTC +8.45', 'UTC +9', 'UTC +9.5', 'UTC +10', 'UTC +10.5', 'UTC +11', 'UTC +12', 'UTC +12.45', 'UTC +13', 'UTC +14'] %}selected{% endif %}>Custom...</option>
                            </select>
                            <input type="text" id="timezone_custom" name="timezone_custom" placeholder="Enter custom timezone (e.g., UTC +5.5)" {% if settings.get('timezone') and settings.get('timezone') not in ['UTC -12', 'UTC -11', 'UTC -10', 'UTC -9.5', 'UTC -9', 'UTC -8.5', 'UTC -8', 'UTC -7', 'UTC -6', 'UTC -5.5', 'UTC -5', 'UTC -4.5', 'UTC -4', 'UTC -3.5', 'UTC -3', 'UTC -2', 'UTC -1', 'UTC', 'UTC +1', 'UTC +2', 'UTC +3', 'UTC +3.5', 'UTC +4', 'UTC +4.5', 'UTC +5', 'UTC +5.5', 'UTC +5.75', 'UTC +6', 'UTC +6.5', 'UTC +7', 'UTC +8', 'UTC +8.45', 'UTC +9', 'UTC +9.5', 'UTC +10', 'UTC +10.5', 'UTC +11', 'UTC +12', 'UTC +12.45', 'UTC +13', 'UTC +14'] %}value="{{ settings.get('timezone') }}"{% endif %} style="{% if settings.get('timezone') and settings.get('timezone') not in ['UTC -12', 'UTC -11', 'UTC -10', 'UTC -9.5', 'UTC -9', 'UTC -8.5', 'UTC -8', 'UTC -7', 'UTC -6', 'UTC -5.5', 'UTC -5', 'UTC -4.5', 'UTC -4', 'UTC -3.5', 'UTC -3', 'UTC -2', 'UTC -1', 'UTC', 'UTC +1', 'UTC +2', 'UTC +3', 'UTC +3.5', 'UTC +4', 'UTC +4.5', 'UTC +5', 'UTC +5.5', 'UTC +5.75', 'UTC +6', 'UTC +6.5', 'UTC +7', 'UTC +8', 'UTC +8.45', 'UTC +9', 'UTC +9.5', 'UTC +10', 'UTC +10.5', 'UTC +11', 'UTC +12', 'UTC +12.45', 'UTC +13', 'UTC +14'] %}display: block{% else %}display: none{% endif %}; margin-top: 8px;">
                        </div>

                        <div class="form-group">
                            <label for="site_name">Site Name</label>
                            <input type="text" id="site_name" name="site_name" value="{{ settings.get('site_name', '') }}">
                        </div>

                        <div class="form-group full-width">
                            <label for="site_description">Site Description</label>
                            <input type="text" id="site_description" name="site_description" value="{{ settings.get('site_description', '') }}">
                        </div>
                    </div>
                </form>
            </div>

            <!-- Data Files Management Section -->
            <div class="settings-card">
                <h3 class="section-title">Data Files Management</h3>
                
                {% set json_files = ['analytics', 'blogs', 'contacts', 'events', 'projects', 'quotes', 'settings'] %}
                
                {% for file_name in json_files %}
                <div class="data-file-group">
                    <div class="file-header">
                        <h4>{{ file_name.replace('_', ' ').title() }}.json</h4>
                        <div class="file-actions">
                            <button type="button" class="btn-small btn-secondary" onclick="downloadDataFile('{{ file_name }}')">
                                <i class="fa-solid fa-download"></i> Download
                            </button>
                            <button type="button" class="btn-small btn-secondary" onclick="openUploadDialog('{{ file_name }}')">
                                <i class="fa-solid fa-upload"></i> Upload
                            </button>
                            <button type="button" class="btn-small btn-secondary" onclick="toggleFileEditor('{{ file_name }}')">
                                <i class="fa-solid fa-edit"></i> Edit
                            </button>
                        </div>
                    </div>
                    
                    <div class="file-editor" id="editor-{{ file_name }}" style="display: none;">
                        <textarea id="textarea-{{ file_name }}" class="file-editor-textarea" placeholder="Loading file content..."></textarea>
                        <div class="editor-actions">
                            <button type="button" class="btn-small btn-primary" onclick="saveFileContent('{{ file_name }}')">
                                <i class="fa-solid fa-floppy-disk"></i> Save
                            </button>
                            <button type="button" class="btn-small btn-secondary" onclick="toggleFileEditor('{{ file_name }}')">
                                <i class="fa-solid fa-times"></i> Cancel
                            </button>
                        </div>
                    </div>
                </div>
                {% endfor %}

                <!-- Hidden file input for uploads -->
                <input type="file" id="fileUploadInput" style="display: none;" accept=".json" onchange="handleFileUpload(event)">
            </div>
        </div>
    </div>
    <script src="{{ url_for('static', filename='js/admin/general-settings.js') }}"></script>
</body>
</html>
