<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="author" content="Jackstar">
    <meta name="copyright" content="RootAccess 2026">
    <meta name="description" content="Analytics dashboard for tracking visitors on RootAccess. Because someone has to watch the watchers.">
    <meta name="keywords" content="{{ 'analytics, dashboard, admin, RootAccess, tracking, big brother, surveillance, metrics' if not keywords else keywords }}">
    <meta name="robots" content="noindex, nofollow">

    <title>RootAccess | Analytics Tracker</title>


    <link rel="preconnect" href="https://cdnjs.cloudflare.com">

    <link rel="shortcut icon" href="{{ url_for('static', filename='assets/images/logos/LogoBrand.png') }}" type="image/x-icon">
    <link rel="preload" href="{{ url_for('static', filename='/assets/fonts/Montserrat/Montserrat-VariableFont_wght.woff2') }}" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="{{ url_for('static', filename='/assets/fonts/Montserrat/Montserrat-Italic-VariableFont_wght.woff2') }}" as="font" type="font/woff2" crossorigin>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <link rel="preload" href="{{ url_for('static', filename='css/root.css') }}" as="style">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/root.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/admin/analytics.css') }}">
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js" crossorigin="anonymous"></script>
</head>
<body>
    <div class="dashboard-layout">
        {% include "admin/sidebar.jinja" %}
        
        <main class="analytics-viewport container" role="main" aria-labelledby="analytics-heading">
            <button class="mobile-menu-btn" id="mobileMenuBtn" type="button" title="Toggle Menu" aria-label="Toggle navigation menu">
                <i class="fa-solid fa-bars"></i>
            </button>
            <h1 id="analytics-heading" class="analytics-title text-gradient">Visitor Analytics</h1>
            <input type="hidden" id="csrf_token" value="{{ generate_token() }}">

            <div class="kpi-grid" role="region" aria-label="Global Statistics">
                <div class="kpi-card" role="status">
                    <i class="fa-solid fa-users" aria-hidden="true"></i>
                    <h3>Total Visits</h3>
                    <p class="kpi-value">{{ total_visits }}</p>
                </div>
                <div class="kpi-card" role="status">
                    <i class="fa-solid fa-user-secret" aria-hidden="true"></i>
                    <h3>Unique Users</h3>
                    <p class="kpi-value">{{ total_unique }}</p>
                </div>
                <div class="kpi-card action-card" onclick="clearData()" role="button" aria-label="Reset all analytics data" tabindex="0">
                    <i class="fa-solid fa-fire" aria-hidden="true"></i>
                    <h3>Reset Everything</h3>
                    <p>Wipe the slate clean.</p>
                </div>
            </div>

            <div class="chart-section">
                <div class="chart-container">
                    <h4 class="chart-label">Traffic Distribution</h4>
                    <div class="canvas-wrapper" aria-label="Visual representation of traffic distribution" role="img">
                        <canvas id="visitorDistributionChart"></canvas>
                    </div>
                </div>
            </div>

            <div class="data-table-container">
                <h2 class="section-subtitle">Endpoint Breakdown</h2>
                <table class="analytics-table" role="grid" aria-label="Detailed per-page analytics">
                    <thead>
                        <tr>
                            <th scope="col">URL Path</th>
                            <th scope="col">Total Visits</th>
                            <th scope="col">Unique</th>
                            <th scope="col">Avg. Time (s)</th>
                            <th scope="col">Management</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in analytics %}
                        <tr>
                            <td class="cell-path"><code>{{ item.url }}</code></td>
                            <td>{{ item.visits }}</td>
                            <td>{{ item.unique_visits }}</td>
                            <td>{{ item.average_time_spent }}s</td>
                            <td>
                                <button class="btn-delete-row" onclick="clearData('{{ item.url }}')" aria-label="Delete analytics for {{ item.url }}">
                                    <i class="fa-solid fa-trash-can" aria-hidden="true"></i>
                                </button>
                                <button class="btn-adjust-row" onclick="openAdjustModal('{{ item.url }}', {{ item.visits }}, {{ item.unique_visits }})" aria-label="Adjust analytics for {{ item.url }}">
                                    <i class="fa-solid fa-sliders" aria-hidden="true"></i>
                                </button>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="data-table-container mt-xl">
                <div class="section-header-row">
                    <h2 class="section-subtitle">Ignored Endpoints</h2>
                    <div class="ignore-input-group">
                        <input type="text" id="newIgnoreUrl" placeholder="e.g. /admin/dashboard" aria-label="Endpoint to ignore">
                        <button class="btn-add" onclick="addIgnoredUrl()" aria-label="Add ignored endpoint">
                            <i class="fa-solid fa-plus" aria-hidden="true"></i> Add
                        </button>
                    </div>
                </div>
                <table class="analytics-table" id="ignoredUrlsTable" role="grid" aria-label="List of ignored endpoints">
                    <thead>
                        <tr>
                            <th scope="col">Ignored Path</th>
                            <th scope="col">Management</th>
                        </tr>
                    </thead>
                    <tbody>
                        </tbody>
                </table>
            </div>

            <!-- Analytics Adjustment Modal -->
            <div id="adjustAnalyticsModal" class="modal" role="dialog" aria-labelledby="adjustModalTitle" aria-hidden="true">
                <div class="modal-content">
                    <div class="modal-header">
                        <h2 id="adjustModalTitle">Adjust Analytics for <code id="adjustModalUrl"></code></h2>
                        <button class="modal-close-btn" onclick="closeAdjustModal()" aria-label="Close dialog">
                            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                        </button>
                    </div>
                    <div class="modal-body">
                        <div class="adjust-form-group">
                            <label for="visitsInput">Visits Change</label>
                            <div class="input-with-buttons">
                                <button type="button" class="btn-decrease" onclick="decreaseVisits()" aria-label="Decrease visits by 1">−</button>
                                <input type="number" id="visitsInput" placeholder="Enter number (positive to add, negative to subtract)" value="0">
                                <button type="button" class="btn-increase" onclick="increaseVisits()" aria-label="Increase visits by 1">+</button>
                            </div>
                            <small>Enter positive numbers to add visits, negative to subtract.</small>
                        </div>
                        
                        <div class="adjust-form-group">
                            <label for="uniqueInput">Unique Visits Change</label>
                            <div class="input-with-buttons">
                                <button type="button" class="btn-decrease" onclick="decreaseUnique()" aria-label="Decrease unique visits by 1">−</button>
                                <input type="number" id="uniqueInput" placeholder="Enter number (positive to add, negative to subtract)" value="0">
                                <button type="button" class="btn-increase" onclick="increaseUnique()" aria-label="Increase unique visits by 1">+</button>
                            </div>
                            <small>Leave at 0 to keep unique visit count unchanged.</small>
                        </div>

                        <div class="adjust-summary">
                            <p><strong>Current:</strong> <span id="currentVisits">0</span> visits · <span id="currentUnique">0</span> unique</p>
                            <p><strong>After adjustment:</strong> <span id="projectedVisits">0</span> visits · <span id="projectedUnique">0</span> unique</p>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button class="btn-cancel" onclick="closeAdjustModal()">Cancel</button>
                        <button class="btn-apply" onclick="applyAnalyticsAdjustment()">Apply Adjustment</button>
                    </div>
                </div>
            </div>

        </main>
    </div>

    <script type="module">
        import { initAnalyticsChart, clearData, loadIgnoredUrls, addIgnoredUrl, removeIgnoredUrl } from "{{ url_for('static', filename='js/admin/chart.js') }}";
        import { initAdjustmentModal } from "{{ url_for('static', filename='js/admin/analytics-adjust.js') }}";

        const analyticsPayload = {
            labels: [{% for item in analytics %}"{{ item.url }}",{% endfor %}],
            datasets: [{
                label: 'Visits',
                data: [{% for item in analytics %}{{ item.visits }},{% endfor %}],
                backgroundColor: 'rgba(37, 161, 167, 0.4)',
                borderColor: '#25A1A7',
                borderWidth: 1
            }]
        };

        initAnalyticsChart('visitorDistributionChart', analyticsPayload);
        initAdjustmentModal();
        
        window.clearData = clearData;
        window.addIgnoredUrl = addIgnoredUrl;
        window.removeIgnoredUrl = removeIgnoredUrl;
        
        document.addEventListener('DOMContentLoaded', loadIgnoredUrls);
    </script>
</body>
</html>