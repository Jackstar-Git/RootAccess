<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="{{ url_for('static', filename='assets/images/logos/LogoBrand.png')}}" type="image">
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://cdnjs.cloudflare.com">

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<link rel="stylesheet" href="{{ url_for('static', filename='css/root.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/admin/admin.css') }}">
    <title>Admin Panel - Dashboard</title>
</head>
<body>
    <div class="main-container">
        {% include "admin/sidebar.jinja" %}
        <main class="main-content container" role="main">
            <h1 class="page-title text-gradient">System & Product Overview</h1>

            <div class="quicklinks-container">
                <a href="/" target="_blank" rel="noopener noreferrer" class="quicklink-card">
                    <i class="fa-solid fa-house" aria-hidden="true"></i>
                    <h3>Homepage</h3>
                    <p>Return to the main page.</p>
                </a>

                <a href="/admin/settings/general" class="quicklink-card">
                    <i class="fa-solid fa-gear" aria-hidden="true"></i>
                    <h3>Settings</h3>
                    <p>Manage system and configuration settings.</p>
                </a>

                <a href="/admin/settings/logs" class="quicklink-card">
                    <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
                    <h3>Logs</h3>
                    <p>View logs, error messages, and server events.</p>
                </a>
            </div>

            <div class="status-container">
                <div class="status-card">
                    <h4>System Status</h4>
                    <div class="status-bars">
                        <div class="status-bar-container">
                            <label><i class="fa-solid fa-microchip"></i> CPU Usage</label>
                            <progress id="cpuProgress" class="low" value="50" max="100" aria-label="CPU Usage"></progress>
                            <span id="cpuUsageText">Loading...</span>
                        </div>
                        <div class="status-bar-container">
                            <label><i class="fa-solid fa-memory"></i> RAM Usage</label>
                            <progress id="ramProgress" class="medium" value="50" max="100" aria-label="RAM Usage"></progress>
                            <span id="ramUsageText">Loading...</span>
                            <p id="ramAdditionalInfo" class="additional-info"></p>
                        </div>
                        <div class="status-bar-container">
                            <label><i class="fa-solid fa-hard-drive"></i> Storage</label>
                            <progress id="storageProgress" class="high" value="50" max="100" aria-label="Storage Usage"></progress>
                            <span id="storageUsageText">Loading...</span>
                            <p id="storageAdditionalInfo" class="additional-info"></p>
                        </div>
                    </div>
                </div>
            </div>

            <button id="refreshBtn" onclick="fetchSystemUsage()" class="btn-secondary" aria-label="Refresh system statistics">
                <i class="fa-solid fa-rotate-right" aria-hidden="true"></i> Refresh Stats
            </button>

            <div class="notes-container">
                <div class="notes-header">
                    <h2>Quick Notes</h2>
                    <button id="editNoteBtn" class="btn-outline" onclick="toggleEditNote()" aria-label="Edit note">
                        <i class="fa-solid fa-pen"></i> Edit
                    </button>
                </div>
                <div id="noteDisplay" class="note-content">
                    {{ html_note | safe }}
                    {% if not raw_note %}
                        <p class="third-font-color"><em>No notes found. Click edit to create one!</em></p>
                    {% endif %}
                </div>
                <div id="noteEditArea" class="hidden-form">
                    <textarea id="noteTextarea" rows="10" placeholder="Write your markdown notes here...">{{ raw_note }}</textarea>
                    <div class="form-actions">
                        <button type="button" class="btn-outline" onclick="toggleEditNote()">Cancel</button>
                        <button type="button" class="btn-secondary" onclick="saveNote()">Save Notes</button>
                    </div>
                </div>
            </div>

            <div class="calendar-container">
                <h2>Calendar</h2>
                <table class="calendar" role="grid" aria-label="Calendar">
                    <thead>
                        <tr>
                            <th colspan="1" class="nav-cell">
                                <button type="button" onclick="changeMonth(-1)" aria-label="Previous month" class="btn-outline">
                                    <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
                                </button>
                            </th>
                            <th colspan="5" id="calendarMonthYear" class="month-year text-primary">
                                {{year}} - {{month}}
                            </th>
                            <th colspan="1" class="nav-cell">
                                <button type="button" onclick="changeMonth(1)" aria-label="Next month" class="btn-outline">
                                    <i class="fa-solid fa-arrow-right" aria-hidden="true"></i>
                                </button>
                            </th>
                        </tr>
                        <tr>
                            <th>Mon</th>
                            <th>Tue</th>
                            <th>Wed</th>
                            <th>Thu</th>
                            <th>Fri</th>
                            <th>Sat</th>
                            <th>Sun</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set day_date = today.replace(month=month, year=year) %}
                        {% for week in calendar %}
                            <tr>
                                {% for day in week %}
                                    {% if day %}
                                        {% set day_date = day_date.replace(day=day) %}
                                        <td
                                            {% if day_date < today %}class="past-day"{% endif %}
                                            {% if day_date == today %}id="today"{% endif %}
                                            role="button"
                                            tabindex="0"
                                            onclick="openModal({{ day }}, {{ month }}, {{ year }})">
                                            <div class="day-number">{{ day }}</div>
                                            <div class="event-count">
                                                {% set event_count = events | selectattr('year', 'equalto', year) | selectattr('month', 'equalto', month) | selectattr('day', 'equalto', day) | list | length %}
                                                {% if event_count > 0 %}
                                                    <span class="event-count-badge">{{ event_count }} Event{% if event_count > 1 %}s{% endif %}</span>
                                                {% else %}
                                                    <span class="event-count-badge empty" aria-hidden="true"></span>
                                                {% endif %}
                                            </div>
                                        </td>
                                    {% else %}
                                        <td class="empty-day past-day"></td>
                                    {% endif %}
                                {% endfor %}
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="modal-overlay" id="modalOverlay" onclick="closeModal()" role="presentation"></div>
            <div class="modal" id="modal" role="dialog" aria-modal="true" aria-labelledby="modalHeader">
                <div class="modal-header">
                    <h3 id="modalHeader" class="text-primary">Day Details</h3>
                    <button class="close-icon btn-outline" onclick="closeModal()" aria-label="Close modal">
                        <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                    </button>
                </div>

                <div id="modalContent" class="modal-body">
                    </div>

                <div class="modal-footer">
                    <button id="addEventBtn" class="btn-secondary" onclick="toggleAddEventForm()" aria-label="Add new event">
                        + Add Event
                    </button>

                    <form id="addEventForm" class="hidden-form" onsubmit="submitEvent(event)" aria-label="Add new event form">
                        <input type="hidden" id="csrf_token" name="csrf_token" value="{{ generate_token() }}">
                        <div class="input-group">
                            <input type="text" id="eventName" placeholder="Event Name" required aria-required="true" class="filter-input">
                        </div>
                        <div class="input-group">
                            <textarea id="eventDescription" placeholder="Event Description" required rows="3" aria-required="true" class="filter-input"></textarea>
                        </div>
                        <div class="form-actions">
                            <button type="button" class="btn-outline" onclick="toggleAddEventForm()">Cancel</button>
                            <button type="submit" class="btn-secondary">Save Event</button>
                        </div>
                    </form>
                </div>
            </div>
        </main>
    </div>

    <script src="{{ url_for('static', filename='js/admin/admin.js') }}"></script>
</body>
</html>