<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="{{ url_for('static', filename='assets/images/logos/LogoBrand.png') }}" type="image/png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://cdnjs.cloudflare.com">

    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" as="font" crossorigin> 
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<link rel="preload" href="{{ url_for('static', filename='css/root.css') }}" as="style">
<link rel="stylesheet" href="{{ url_for('static', filename='css/root.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/admin/all-blogs.css') }}">
    <title>Admin Panel - All Blogs</title>
</head>
<body>
    <div class="main-container">
        {% include "admin/sidebar.jinja" %}

        <div class="main-content">
            <button class="mobile-menu-btn" id="mobileMenuBtn" type="button" title="Toggle Menu" aria-label="Toggle navigation menu">
                <i class="fa-solid fa-bars"></i>
            </button>
            <div class="header-actions">
                <h2>Blogs Overview</h2>
                <a href="/admin/blogs/create" class="btn btn-primary"><i class="fas fa-plus"></i> New Post</a>
            </div>
            
            <div class="blog-filters">
                <form class="search-bar" method="GET" action="/admin/blogs/all">
                    <input type="hidden" name="csrf_token" id="csrf_token" value="{{ generate_token() }}">
                    <input type="hidden" name="category" value="{{ query_params.get('category', 'all') }}">
                    <input type="text" name="search" id="search-input" placeholder="Search by title or author..." value="{{ query_params.get('search', '') }}">
                    <button type="submit" style="display: none;">Search</button>
                </form>

                <div class="sort-options">
                    <select id="sort-options" onchange="window.location.href=this.value">
                        <option value="">Sort by</option>
                        <option value="?sort=newest">Newest First</option>
                        <option value="?sort=oldest">Oldest First</option>
                        <option value="?sort=title-asc">Title: A-Z</option>
                        <option value="?sort=title-desc">Title: Z-A</option>
                    </select>
                </div>

                <div class="filter-menu">
                    <select id="category-filter" onchange="window.location.href='?topic=' + this.value">
                        <option value="all">All Topics</option>
                        {% for topic in settings.topics %}
                            <option {% if query_params.get('topic') == topic %}selected{% endif %} value="{{ topic }}">{{ topic }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            <div class="blogs-list">
                {% if blogs|length == 0 %}
                    <div class="empty-state">
                        <h3>No matching blog posts found!</h3>
                        <a href="/admin/blogs/all" class="btn view-btn">Clear Filters</a>
                    </div>
                {% endif %}

                {% for blog in blogs %}
                    <div class="blog-item">
                        <div class="id-column">{{ blog.id }}</div>
                        
                        <img src="{{ blog.image_url }}" alt="Thumbnail for {{ blog.title }}" class="blog-thumbnail">

                        <div class="blog-info">
                            <h3><a href="/admin/blogs/edit/{{ blog.id }}">{{ blog.title }}</a></h3>
                            <p class="categories-tags">
                                <i class="fas fa-folder"></i> {{ blog.categories | join(', ') }} 
                                {% if blog.tags %}
                                    &nbsp;|&nbsp; <i class="fas fa-hashtag"></i> {{ blog.tags | join(', ') }}
                                {% endif %}
                            </p>
                        </div>

                        <div class="blog-meta">
                            {% if blog.status == 'visible' %}
                                <span class="status-badge status-visible"><i class="fas fa-eye"></i> Visible</span>
                            {% elif blog.status == 'hidden' %}
                                <span class="status-badge status-hidden"><i class="fas fa-eye-slash"></i> Hidden</span>
                            {% else %}
                                <span class="status-badge status-draft"><i class="fas fa-pencil-alt"></i> Draft</span>
                            {% endif %}
                            <br>
                            <span class="author"><i class="fas fa-user-edit"></i> {{ blog.author | join(', ') }}</span>
                            <br>    
                            <span class="date"><i class="fas fa-calendar-alt"></i> {{ blog.time_created | datetimeformat }}</span>
                        </div>

                        <div class="blog-actions">
                            <a href="/blog/{{ blog.id }}" target="_blank" rel="noopener noreferrer" class="btn view-btn" title="View Live"><i class="fas fa-external-link-alt"></i></a>
                            <a href="/admin/blogs/edit/{{ blog.id }}" class="btn edit-btn" title="Edit Post"><i class="fas fa-edit"></i></a>
                            <button class="btn delete-btn" onclick="deletePost('{{blog.id}}')" title="Delete Post"><i class="fas fa-trash-alt"></i></button>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
    <script src="{{ url_for('static', filename='js/admin/admin-global.js')}}"></script>
</body>
</html>