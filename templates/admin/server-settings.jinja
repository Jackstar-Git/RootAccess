<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="{{ url_for('static', filename='assets/images/logos/LogoBrand.png') }}" type="image">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@100..900&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/root.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/admin/server-settings.css') }}">
    <title>Server Settings</title>
</head>
<body>
    <div class="main-container">
        {% include "admin/sidebar.jinja" %}
        <div class="main-content">
            <button class="mobile-menu-btn" id="mobileMenuBtn" type="button" title="Toggle Menu" aria-label="Toggle navigation menu">
                <i class="fa-solid fa-bars"></i>
            </button>
            <input type="hidden" id="csrf_token" value="{{ generate_token() }}">
            
            <div class="filter-bar">
                <div class="filter-controls">
                    <h2>Server Configuration</h2>
                </div>
                <button class="btn-primary" onclick="submitServerSettings()">
                    <i class="fa-solid fa-floppy-disk"></i> Save Settings
                </button>
                <button class="btn-danger" onclick="clearGlobalCache()">
                    <i class="fa-solid fa-broom"></i> Clear Cache
                </button>
            </div>

            <div class="settings-card">
                <form id="serverSettingsForm">
                    <div class="settings-grid">
                        <div class="form-group checkbox-group">
                            <label for="maintenance">Maintenance Mode</label>
                            <input type="checkbox" id="maintenance" name="maintenance" {% if server_config.maintenance %}checked{% endif %}>
                        </div>

                        <div class="form-group">
                            <label for="max_content_length">Max Content Length (Bytes)</label>
                            <input type="number" id="max_content_length" name="max_content_length" value="{{ server_config.MAX_CONTENT_LENGTH or 12582912 }}">
                        </div>

                        <div class="form-group">
                            <label for="session_cookie_name">Session Cookie Name</label>
                            <input type="text" id="session_cookie_name" name="session_cookie_name" value="{{ server_config.SESSION_COOKIE_NAME or 'session' }}">
                        </div>

                        <div class="form-group">
                            <label for="permanent_session_lifetime">Session Lifetime (Seconds)</label>
                            <input type="number" id="permanent_session_lifetime" name="permanent_session_lifetime" value="{{ server_config.PERMANENT_SESSION_LIFETIME or 1800 }}">
                        </div>

                        <div class="form-group checkbox-group">
                            <label for="session_cookie_httponly">HttpOnly Cookie</label>
                            <input type="checkbox" id="session_cookie_httponly" name="session_cookie_httponly" {% if server_config.SESSION_COOKIE_HTTPONLY != False %}checked{% endif %}>
                        </div>

                        <div class="form-group checkbox-group">
                            <label for="session_cookie_secure">Secure Cookie (HTTPS)</label>
                            <input type="checkbox" id="session_cookie_secure" name="session_cookie_secure" {% if server_config.SESSION_COOKIE_SECURE != False %}checked{% endif %}>
                        </div>

                        <div class="form-group">
                            <label for="session_cookie_samesite">SameSite Policy</label>
                            <select id="session_cookie_samesite" name="session_cookie_samesite">
                                <option value="Lax" {% if server_config.SESSION_COOKIE_SAMESITE == 'Lax' %}selected{% endif %}>Lax</option>
                                <option value="Strict" {% if server_config.SESSION_COOKIE_SAMESITE == 'Strict' %}selected{% endif %}>Strict</option>
                                <option value="None" {% if server_config.SESSION_COOKIE_SAMESITE == 'None' %}selected{% endif %}>None</option>
                            </select>
                        </div>
                    </div>

                    <div class="form-group full-width" style="margin-top: 20px;">
                        <label for="robots_txt">Edit robots.txt</label>
                        <textarea id="robots_txt" name="robots_txt" rows="12" placeholder="User-agent: *...">{{ robots_txt }}</textarea>
                    </div>
                </form>
            </div>
        </div>
    </div>
    <script src="{{ url_for('static', filename='js/admin/server-settings.js') }}"></script>
</body>
</html>