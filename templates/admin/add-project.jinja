<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="{{ url_for('static', filename='assets/images/logos/LogoBrand.png') }}" type="image">
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://cdnjs.cloudflare.com">

    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" as="font" crossorigin> 
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap">

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">

<link rel="preload" href="{{ url_for('static', filename='css/root.css') }}" as="style">
<link rel="stylesheet" href="{{ url_for('static', filename='css/root.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/admin/edit-project.css') }}">
    <title>Admin - Draft New Project</title>
</head>
<body>
    <div class="main-container">
        {% include "admin/sidebar.jinja" %}

        <main class="main-content">
            <button class="mobile-menu-btn" id="mobileMenuBtn" type="button" title="Toggle Menu" aria-label="Toggle navigation menu">
                <i class="fa-solid fa-bars"></i>
            </button>
            <header class="editor-header">
                <h2>Draft New Project</h2>
                <div class="header-actions">
                    <a href="/admin/projects/all" class="btn-discard" onclick="return confirm('Discard changes?')">Discard</a>
                </div>
            </header>

            <form method="POST" action="{{ url_for('admin.create_project') }}" enctype="multipart/form-data" class="modern-form" id="project-form">
                <input type="hidden" name="csrf_token" id="csrf_token" value="{{ generate_token() }}">

                <div class="editor-layout">
                    <section class="content-area">
                        <div class="title-version-group">
                            <input type="text" id="title" name="title" class="title-input" placeholder="Project Title" required>
                            <input type="text" id="version" name="version" class="version-input" placeholder="v1.0.0" required>
                        </div>
                        
                        <textarea id="description_short" name="description_short" class="short-desc-input" placeholder="Write a short summary of the project..." required></textarea>

                        <div class="toolbar-sticky">
                            <div class="toolbar">
                                <button type="button" onclick="applyStyle('bold')" title="Bold"><i class="fas fa-bold"></i></button>
                                <button type="button" onclick="applyStyle('italic')" title="Italic"><i class="fas fa-italic"></i></button>
                                <button type="button" onclick="applyStyle('underline')" title="Underline"><i class="fas fa-underline"></i></button>
                                <button type="button" onclick="applyStyle('strikethrough')" title="Strikethrough"><i class="fas fa-strikethrough"></i></button>

                                <span class="divider"></span>

                                <button type="button" onclick="applyStyle('superscript')" title="Superscript"><i class="fas fa-superscript"></i></button>
                                <button type="button" onclick="applyStyle('subscript')" title="Subscript"><i class="fas fa-subscript"></i></button>
                                <button type="button" onclick="applyColor()" title="Text Color"><i class="fas fa-palette"></i></button>

                                <span class="divider"></span>

                                <select onchange="applyAlignment(this.value); this.value='';" class="toolbar-select">
                                    <option value="" disabled selected>Align</option>
                                    <option value="left">Left</option>
                                    <option value="center">Center</option>
                                    <option value="right">Right</option>
                                </select>

                                <button type="button" onclick="applyLineStyle('blockquote')" title="Quote"><i class="fas fa-quote-right"></i></button>
                                <button type="button" onclick="applyLineStyle('codeblock')" title="Code Block"><i class="fas fa-code"></i></button>
                                <button type="button" onclick="applyStyle('inlinecode')" title="Inline Code"><i class="fas fa-terminal"></i></button>

                                <select onchange="applyLineStyle(this.value); this.value='';" class="toolbar-select">
                                    <option value="" disabled selected>H</option>
                                    <option value="h1">H1</option>
                                    <option value="h2">H2</option>
                                    <option value="h3">H3</option>
                                </select>

                                <button type="button" onclick="addLink()" title="Link"><i class="fas fa-link"></i></button>
                                <button type="button" onclick="applyLineStyle('html')" title="HTML Injection"><i class="fab fa-html5"></i></button>

                                <span class="divider"></span>

                                <button type="button" id="toggle-view-button" onclick="toggleView()" class="btn-preview">
                                    <i class="fas fa-eye"></i> Preview
                                </button>
                            </div>
                        </div>

                        <textarea id="content" name="content_raw" placeholder="Detailed project documentation or breakdown..."></textarea>
                        <div id="preview-output" class="markdown-body" style="display: none;"></div>
                    </section>

                    <aside class="settings-sidebar">
                        <div class="settings-group">
                            <label>Featured Image</label>
                            <div class="upload-container" id="drop-zone">
                                <input type="file" id="thumbnail-upload" name="thumbnail" accept="image/*" hidden>
                                <div id="thumbnail-preview" class="preview-box">
                                    <i class="fas fa-cloud-upload-alt"></i>
                                    <p>Click to upload</p>
                                </div>
                            </div>
                        </div>

                        <div class="settings-group">
                            <label>Tech Stack</label>
                            <div id="tech-list">
                                <div class="dynamic-input">
                                    <input name="tech_stack[]" type="text" placeholder="e.g. Python" required>
                                </div>
                            </div>
                            <button type="button" class="btn-add" onclick="addTech()">+ Add Technology</button>
                        </div>

                        <div class="settings-group">
                            <label>External Links</label>
                            <input type="url" name="github_url" class="modern-input link-input" placeholder="GitHub Repository URL">
                            <input type="url" name="demo_url" class="modern-input link-input" placeholder="Live Demo URL">
                            <input type="text" name="download_file" class="modern-input link-input" placeholder="Downloadable File Name">
                        </div>

                        <div class="settings-group">
                            <label>Topic / Category</label>
                            <select name="topic" class="modern-select" required>
                                {% for topic in settings.topics %}
                                    <option value="{{ topic }}">{{ topic }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="settings-group">
                            <label>Tags (Comma separated)</label>
                            <input type="text" name="tags" class="modern-input" placeholder="automation, gui, web...">
                        </div>

                        <div class="settings-group">
                            <label>Maturity</label>
                            <select name="maturity" class="modern-select">
                                {% for maturity in settings.maturity_levels %}
                                    <option value="{{ maturity }}">{{ maturity }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <div class="settings-group">
                            <label>Activity</label>
                            <select name="activity" class="modern-select">
                                {% for activity in settings.activity_statuses %}
                                    <option value="{{ activity }}">{{ activity }}</option>
                                {% endfor %}
                            </select>
                        </div>

                        <button type="submit" class="btn-primary btn-publish">Publish Project</button>
                    </aside>
                </div>
            </form>
        </main>
    </div>
    <script src="{{ url_for('static', filename='js/admin/edit-project.js')}}"></script>
</body>
</html>