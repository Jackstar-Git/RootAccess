<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>About me // RootAccess — Jackstar's digital footprint</title>
    <meta name="description" content="A brief overview of how I spend my time trying to convince computers to work. Based in Austria, fueled by curiosity and caffeine.">
    <meta name="author" content="Jackstar">
    <meta name="keywords" content="Jackstar, RootAccess, Austrian Developer, Python, Flask, Bento Grid Portfolio">
    <meta name="robots" content="index, follow">
    <meta name="copyright" content="© 2026 RootAccess. All rights and wrongs reserved.">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" as="font" crossorigin>
    <link rel="preload" href="{{ url_for('static', filename='css/root.css') }}" as="style">

    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/root.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/about.css') }}">

    <link rel="shortcut icon" href="{{ url_for('static', filename='assets/images/logos/LogoBrand.png') }}" type="image/png">
</head>
<body>
    {% include "snippets/navbar.jinja" %}
    
    <main class="glass-page-container" role="main">
        <div class="bento-grid" aria-label="Personal information bento grid">
            
            <section class="glass-element profile-hero" aria-labelledby="hero-heading">
                <div class="hero-content">
                    <div class="profile-sidebar">
                        <div class="avatar-container">
                            <img src="{{ url_for('static', filename='assets/images/logos/Logo.png') }}" alt="Jackstar's Avatar" class="hero-avatar">
                            <span class="flag-icon" role="img" aria-label="Austria">🇦🇹</span>
                        </div>
                        <div class="personal-meta">
                            <span class="meta-tag"><i class="fas fa-user" aria-hidden="true"></i> he/him</span>
                            <span class="meta-tag"><i class="fas fa-clock" aria-hidden="true"></i> CE(S)T</span>
                        </div>
                    </div>
                    
                    <div class="hero-info">
                        <h1 class="greeting-inline" id="hero-heading">Hi there <img src="{{ url_for('static', filename='assets/waving-hand.gif') }}" alt="Waving hand animation" aria-hidden="true"></h1>
                        <p class="tagline">Developer from Austria</p>
                        
                        <div class="about-text">
                            <p>I tell computers what to do since <strong>July 2021</strong>. Sometimes they listen, mostly they don't. 🤷‍♂️</p>
                        </div>

                        <div class="quote-box" aria-label="Quote of the day">
                            <i class="fas fa-quote-left" aria-hidden="true"></i> <span class="sr-only">QOTD:</span>
                            <p id="daily-quote">"{{ quote.text }}"</p>
                            <cite>– {{ quote.author or "A wise person" }}</cite>
                        </div>
                    </div>
                </div>
            </section>

            <section class="glass-element skills-sidebar" aria-labelledby="skills-heading">
                <div class="skill-group">
                    <h3 id="skills-heading"><i class="fas fa-terminal" aria-hidden="true"></i> Coding</h3>
                    <div class="skill-item">
                        <div class="skill-label">
                            <div class="icon-label"><img src="{{ url_for('static', filename='assets/images/logos/python-original.svg') }}" alt="" aria-hidden="true"> Python</div>
                            <span>90%</span>
                        </div>
                        <div class="progress-bar" role="progressbar" aria-valuenow="90" aria-valuemin="0" aria-valuemax="100"><div class="progress-fill" style="--target-width: 90%;"></div></div>
                    </div>
                    <div class="skill-item">
                        <div class="skill-label">
                            <div class="icon-label"><img src="{{ url_for('static', filename='assets/images/logos/html5-original.svg') }}" alt="" aria-hidden="true"> HTML5</div>
                            <span>95%</span>
                        </div>
                        <div class="progress-bar" role="progressbar" aria-valuenow="95" aria-valuemin="0" aria-valuemax="100"><div class="progress-fill" style="--target-width: 95%;"></div></div>
                    </div>
                    <div class="skill-item">
                        <div class="skill-label">
                            <div class="icon-label"><img src="{{ url_for('static', filename='assets/images/logos/css3-original.svg') }}" alt="" aria-hidden="true"> CSS3</div>
                            <span>85%</span>
                        </div>
                        <div class="progress-bar" role="progressbar" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100"><div class="progress-fill" style="--target-width: 85%;"></div></div>
                    </div>
                    <div class="skill-item">
                        <div class="skill-label">
                            <div class="icon-label"><img src="{{ url_for('static', filename='assets/images/logos/javascript-original.svg') }}" alt="" aria-hidden="true"> JavaScript</div>
                            <span>60%</span>
                        </div>
                        <div class="progress-bar" role="progressbar" aria-valuenow="60" aria-valuemin="0" aria-valuemax="100"><div class="progress-fill" style="--target-width: 60%;"></div></div>
                    </div>
                </div>

                <div class="skill-group spoken">
                    <h3><i class="fas fa-comments" aria-hidden="true"></i> Spoken</h3>
                    <div class="skill-item spoken-lang-item">
                        <div class="skill-label">
                            <div class="icon-label"><img src="{{ url_for('static', filename='assets/images/flags/at.png') }}" alt="" aria-hidden="true"> German</div>
                            <span>Native</span>
                        </div>
                        <div class="progress-bar" role="progressbar" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"><div class="progress-fill gold" style="--target-width: 100%;"></div></div>
                    </div>
                    <div class="skill-item spoken-lang-item">
                        <div class="skill-label">
                            <div class="icon-label"><img src="{{ url_for('static', filename='assets/images/flags/gb.png') }}" alt="" aria-hidden="true"> English</div>
                            <span>Fluent</span>
                        </div>
                        <div class="progress-bar" role="progressbar" aria-valuenow="85" aria-valuemin="0" aria-valuemax="100"><div class="progress-fill gold" style="--target-width: 85%;"></div></div>
                    </div>
                    <div class="skill-item spoken-lang-item">
                        <div class="skill-label">
                            <div class="icon-label"><img src="{{ url_for('static', filename='assets/images/flags/es.png') }}" alt="" aria-hidden="true"> Spanish</div>
                            <span>Basic</span>
                        </div>
                        <div class="progress-bar" role="progressbar" aria-valuenow="25" aria-valuemin="0" aria-valuemax="100"><div class="progress-fill gold" style="--target-width: 25%;"></div></div>
                    </div>
                </div>
            </section>

            <section class="glass-element libraries-box" aria-labelledby="libraries-heading">
                <h3 id="libraries-heading"><i class="fas fa-layer-group" aria-hidden="true"></i> Libraries & Frameworks</h3>
                <div class="tool-grid">
                    <div class="tool-item">
                        <img src="{{ url_for('static', filename='assets/images/logos/flask-original.svg') }}" alt="Flask logo">
                        <span>Flask</span>
                    </div>
                    <div class="tool-item">
                        <img src="{{ url_for('static', filename='assets/images/logos/jinja-original.svg') }}" alt="Jinja2 logo">
                        <span>Jinja2</span>
                    </div>
                    <div class="tool-item">
                        <img src="{{ url_for('static', filename='assets/images/logos/streamlit-plain.svg') }}" alt="Streamlit logo">
                        <span>Streamlit</span>
                    </div>
                </div>
            </section>

            <section class="glass-element tools-box" aria-labelledby="toolbox-heading">
                <h3 id="toolbox-heading"><i class="fas fa-box-open" aria-hidden="true"></i> Toolbox</h3>
                <div class="tool-grid">
                    <div class="tool-item">
                        <img src="{{ url_for('static', filename='assets/images/logos/mongodb-original.svg') }}" alt="MongoDB">
                        <span>MongoDB</span>
                    </div>
                    <div class="tool-item">
                        <img src="{{ url_for('static', filename='assets/images/logos/github-original.svg') }}" alt="GitHub">
                        <span>GitHub</span>
                    </div>
                    <div class="tool-item">
                        <img src="{{ url_for('static', filename='assets/images/logos/markdown-original.svg') }}" alt="Markdown">
                        <span>Markdown</span>
                    </div>
                    <div class="tool-item">
                        <img src="{{ url_for('static', filename='assets/images/logos/json-original.svg') }}" alt="JSON">
                        <span>JSON</span>
                    </div>
                </div>
            </section>

            <section class="glass-element learning-path" aria-labelledby="learning-heading">
                <h3 id="learning-heading"><i class="fas fa-rocket" aria-hidden="true"></i> Currently Learning</h3>
                <ul class="path-list">
                    <li><img src="{{ url_for('static', filename='assets/images/logos/cplusplus-original.svg') }}" width="20" alt="C++ logo"> C++</li>
                    <li><img src="{{ url_for('static', filename='assets/images/logos/pytorch-original.svg') }}" width="20" alt="PyTorch logo"> PyTorch</li>
                    <li><i class="fas fa-database" style="color: var(--main-color-500);" aria-hidden="true"></i> MySQL</li>
                    <li><img src="{{ url_for('static', filename='assets/images/logos/pandas-original.svg') }}" width="20" alt="Pandas logo"> Pandas</li>
                    <li><img src="{{ url_for('static', filename='assets/images/logos/numpy-original.svg') }}" alt="NumPy logo" width="20"> NumPy</li>
                </ul>
            </section>

            <section class="glass-element contact-box" aria-label="Contact information">
                <p>Want to build something together?</p>
                <a href="https://discordapp.com/users/700285395589529702" class="discord-pill" rel="noopener">
                    <i class="fab fa-discord" aria-hidden="true"></i> Connect on Discord
                </a>
            </section>
        </div>
    </main>
    {% include "snippets/footer.jinja" %}
    <script src="{{ url_for('static', filename='js/global.js') }}"></script>
</body>
</html>