<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Projects – Jackstar’s Portfolio</title>
    <meta name="description" content="A curated showcase of projects by Jackstar covering fintech, AI/ML, and creative work.">
    <meta name="author" content="Jackstar">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/root.css') }}">
    <link rel="stylesheet" href="{{ url_for('static', filename='css/projects.css') }}">
    <link rel="shortcut icon" href="{{ url_for('static', filename='assets/images/logos/LogoBrand.png') }}" type="image/png">
</head>
<body>
    {% include "snippets/navbar.jinja-html" %}

    <main class="project-page-wrapper container">
        <header class="project-header">
            <div class="project-label">Portfolio</div>
            <h1>Selected Projects</h1>
        </header>

        <section class="project-toolbar">
            <div class="search-wrapper">
                <input type="text" placeholder="Search articles..." id="search-input">
                <i class="fa-solid fa-magnifying-glass search-icon"></i>
            </div>
            
            <button class="filter-toggle-btn" id="filter-btn">
                <i class="fa-solid fa-sliders"></i>
                <span>Filters</span>
            </button>
        </section>

        <section class="filter-drawer" id="filter-drawer">
            <div class="drawer-inner">
                <div class="filter-col filter-group">
                    <label><i class="fa-solid fa-sort"></i> Sort</label>
                    <div class="filter-select-wrapper">
                        <select id="sort-select">
                            <option value="newest">🔽 Newest</option>
                            <option value="oldest">🔼 Oldest</option>
                        </select>
                        <i class="fa-solid fa-chevron-down dropdown-icon"></i>
                    </div>
                </div>
                <div class="filter-col filter-group">
                    <label><i class="fa-solid fa-folder-open"></i> Topics</label>
                    <div class="filter-select-wrapper">
                        <select id="category-select">
                            <option value="">All</option>
                            {% for topic in settings.topics %}
                                <option>{{ topic }}</option>
                            {% endfor %}
                        </select>
                        <i class="fa-solid fa-chevron-down dropdown-icon"></i>
                    </div>
                </div>
                <div class="filter-col filter-group">
                    <label><i class="fa-solid fa-tags"></i> Tech Stack</label>
                    <div class="tag-input">
                        <input type="text" placeholder="e.g. Python, JavaScript, HTML" id="tags-input">
                        <div class="tag-suggestions">
                            <span>#Python</span>
                            <span>#JavaScript</span>
                            <span>#HTML</span>
                        </div>
                    </div>
                </div>
                <div class="filter-col filter-group">
                    <label><i class="fa-solid fa-calendar-days"></i> Date</label>
                    <div class="filter-date-range">
                        <input type="date" id="start-date"><span>to</span><input type="date" id="end-date">
                    </div>
                </div>
                
                <div class="filter-col filter-group">
                    <label><i class="fa-solid fa-clock"></i> Activity</label>
                    
                    <select name="reading_time" class="native-multiselect" multiple>
                        {% for activity in settings.activity_statuses %}
                            <option value="{{ activity }}">{{ activity }}</option>
                        {% endfor %}
                    </select>

                    <div class="custom-multiselect" id="reading-time-multiselect" style="display: none;">
                        <div class="multiselect-header">
                            <div class="multiselect-pills"></div>
                            <input type="text" class="multiselect-search" placeholder="Search...">
                            <i class="fa-solid fa-chevron-down dropdown-icon"></i>
                        </div>
                        <div class="multiselect-dropdown">
                            <div class="multiselect-actions">
                                <label><input type="checkbox" class="select-all"> Select All</label>
                            </div>
                            <div class="multiselect-options">
                                {% for activity in settings.activity_statuses %}
                                    <label class="filter-list-item"><input type="checkbox" value="{{ activity }}"> <span>{{ activity }}</span></label>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="filter-col filter-group">
                    <label><i class="fa-solid fa-bars-progress"></i> Maturity</label>
                    
                    <select name="maturity" class="native-multiselect" multiple>
                        {% for maturity in settings.maturity_levels %}
                            <option value="{{ maturity }}">{{ maturity }}</option>
                        {% endfor %}
                    </select>

                    <div class="custom-multiselect" id="type-multiselect" style="display: none;">
                        <div class="multiselect-header">
                            <div class="multiselect-pills"></div>
                            <input type="text" class="multiselect-search" placeholder="Search...">
                            <i class="fa-solid fa-chevron-down dropdown-icon"></i>
                        </div>
                        <div class="multiselect-dropdown">
                            <div class="multiselect-actions">
                                <label><input type="checkbox" class="select-all"> Select All</label>
                            </div>
                            <div class="multiselect-options">
                                {% for maturity in settings.maturity_levels %}
                                    <label class="filter-list-item">
                                        <input type="checkbox" value="{{ maturity }}">
                                        <span>{{ maturity }}</span>
                                    </label>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>

            </div>
            <div class="filter-actions">
                <button class="clear-filters-btn"><i class="fa-solid fa-rotate-left"></i> Clear All</button>
                <button class="apply-filters-btn"><i class="fa-solid fa-check"></i> Apply Filters</button>
            </div>
        </section>

        <section class="project-main-grid">
           {% if projects %}
                {% for project in projects %}
                    {% include "snippets/project_card.jinja-html" %}
                {% endfor %}
            {% else %}
                <p class="no-results">
                    {% if search_query %}
                        No projects found matching "{{ search_query }}". Try different keywords.
                    {% else %}
                        No projects found with the current filters. Try adjusting your search criteria.
                    {% endif %}
                </p>
            {% endif %}
        </section>
    </main>
    {% include "snippets/footer.jinja-html" %}
    <script src="{{ url_for('static', filename='js/global.js') }}"></script>
    <script src="{{ url_for('static', filename='js/projects.js') }}"></script>

</body>
</html>